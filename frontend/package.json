{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --fix src && prettier --write ./src && tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "gql-gen": "NODE_TLS_REJECT_UNAUTHORIZED=0 graphql-codegen --config gql-codegen.config.ts",
    "test": "vitest",
    "test-ui": "vitest --ui",
    "test-run": "vitest run",
    "test-coverage": "vitest run --coverage",
    "test-unit": "vitest run --project unit",
    "test-integration": "vitest run --project integration"
  },
